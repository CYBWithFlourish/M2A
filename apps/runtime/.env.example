# M2A Runtime Configuration
# Convention: All network-specific env vars (including all DeFi package addresses and protocol IDs) use _{SUI_NETWORK} suffix.
# Set SUI_NETWORK=mainnet → code reads VAR_mainnet
# Set SUI_NETWORK=testnet  → code reads VAR_testnet
# Everything must be supplied explicitly for both networks.

# Target Sui network - drives all env var suffix resolution
SUI_NETWORK=testnet

# Server
M2A_RUNTIME_PORT=3001

# MemWal
MEMWAL_MODE=self
SERVER_SUI_PRIVATE_KEY=
MEMWAL_RELAYER_URL_self=http://localhost:8000
MEMWAL_PLATFORM_ACCOUNT_ID_testnet=
MEMWAL_PLATFORM_ACCOUNT_ID_mainnet=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/m2a

# Policy Gateway
M2A_GATEWAY_URL=http://localhost:4010

# Network-Specific Env Vars (always suffix with _testnet / _mainnet)

# Sui RPC URLs - required for mainnet
SUI_RPC_URL_testnet=https://fullnode.testnet.sui.io:443
SUI_RPC_URL_mainnet=https://fullnode.mainnet.sui.io:443

# M2A Smart Contracts
M2A_PACKAGE_ID_testnet=
M2A_PACKAGE_ID_mainnet=
M2A_REGISTRY_ID_testnet=
M2A_REGISTRY_ID_mainnet=

# Cetus DeFi
CETUS_PACKAGE_ID_testnet=
CETUS_PACKAGE_ID_mainnet=
CETUS_INTEGRATE_PACKAGE_testnet=0x19dd42e05fa6c9988a60d30686ee3feb776672b5547e328d6dab16563da65293
CETUS_INTEGRATE_PACKAGE_mainnet=
CETUS_GLOBAL_CONFIG_ID_testnet=0x9774e359588ead122af1c7e7f64e14ade261cfeecdb5d0eb4a5b3b4c8ab8bd3e
CETUS_GLOBAL_CONFIG_ID_mainnet=

# DeepBook
DEEPBOOK_PACKAGE_ID_testnet=
DEEPBOOK_PACKAGE_ID_mainnet=

# DeFi Protocol Package Addresses (network-aware)
BLUEFIN_PACKAGE_ID_testnet=0x1c540fb6c51d53e0c1ceb11aafc4c8db1a8e2764d857440510c34b3a03c9c3b2
BLUEFIN_PACKAGE_ID_mainnet=
VOLO_PACKAGE_ID_testnet=0x549e8b69270defbfafd4f94e17ec44cdbdd99820b33bda2278dea3b9a32d3f55
VOLO_PACKAGE_ID_mainnet=
HAEDAL_PACKAGE_ID_testnet=0xbde4ba4c2e274a60ce15c1cfff9e5c42e41654ac8b6d906a57efa4bd3c29f47d
HAEDAL_PACKAGE_ID_mainnet=
WORMHOLE_PACKAGE_ID_testnet=0x5306f64e312b581766351c07af79c72fcb1cd25147157fdc2f8ad76de9a3fb6a
WORMHOLE_PACKAGE_ID_mainnet=
WORMHOLE_STATE_ID_testnet=0xaeab97f96cf9877fee2883315d459552b2b921edc16d7ceac6eab944dd88919c
WORMHOLE_STATE_ID_mainnet=
SUI_BRIDGE_PACKAGE_ID_testnet=0x9cf66f15bc07651af26ad0f79397c88cf03679b1b55a89cce5984f7bb27c8bda
SUI_BRIDGE_PACKAGE_ID_mainnet=
ALPHAFI_PACKAGE_ID_testnet=
ALPHAFI_PACKAGE_ID_mainnet=
BUCKET_PACKAGE_ID_testnet=0xce7ff77a83ea0cb6fd39bd8748e2ec89a3f41e8efdc3f4eb123e0ca37b184db2
BUCKET_PACKAGE_ID_mainnet=
BUCKET_TREASURY_ID_testnet=
BUCKET_TREASURY_ID_mainnet=

# Walrus Storage URLs - required for mainnet
WALRUS_PUBLISHER_URL_testnet=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL_testnet=https://aggregator.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL_mainnet=https://aggregator.walrus-mainnet.walrus.space

# Walrus sidecar (local dev only, not network-specific)
WALRUS_SIDECAR_URL=http://localhost:9000

# Search Provider (for WebSearchTool)
# Default: duckduckgo (free, no key needed)
# Options: tavily, serpapi, duckduckgo
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Agent Runner
AGENT_RUNNER_MAX_LOOPS=25

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=
TELEGRAM_BOT_TOKEN=

# Server Config
FRONTEND_URL=http://localhost:5173
MCP_MODE=
HTTPS_REDIRECT=
RATE_LIMIT_MAX=100
RATE_LIMIT_EXECUTE_MAX=20
RATE_LIMIT_AUTHZ_MAX=30

# Authorization
M2A_BLOCKED_TOOLS=
M2A_BLOCKED_ACTIONS=
