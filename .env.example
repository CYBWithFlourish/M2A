# M2A Platform Environment Configuration Example
# Copy to .env and adjust values accordingly

# M2A Engine & Runtime Settings
M2A_RUNTIME_PORT=3001

# Primary LLM: Llama 4 Maverick via Groq — fastest inference, tool-use native, 1M context window
GROQ_API_KEY=your_groq_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Sui Network (used for hosted relayer URLs and env var suffix resolution)
SUI_NETWORK=testnet

# MemWal Configs

# Mode: "self" (local postgres+redis+relayer) or "hosted" (external MemWal service)
MEMWAL_MODE=self

# Relayer Server URL used by our SDK and Node Runtime
# (auto-derived from SUI_NETWORK in hosted mode)
MEMWAL_RELAYER_URL=http://localhost:8000

# Sui & Blockchain Network Settings
MEMWAL_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6
MEMWAL_REGISTRY_ID=0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437

# In hosted mode: platform account ID (network-suffixed preferred)
MEMWAL_PLATFORM_ACCOUNT_ID_testnet=0x...
MEMWAL_PLATFORM_ACCOUNT_ID_mainnet=0x...

# SEAL key servers (testnet - see https://seal-docs.wal.app for updates)
SEAL_KEY_SERVERS="[
  \"0x3937a01b772245f2f9c6a5370084c93f97d62d5c42de54bf061dfbe600cbfe90\",
  \"0xef073bc30527d24d305b47c6cc4687897c7e93072d4b4e3c6bf2bfe956df0489\"
]"

# Your platform wallet (private key generated via sui CLI)
# This Sui account will own the global shared namespaces
SERVER_SUI_PRIVATE_KEY=

# Infrastructure Services

# PostgreSQL connection string
# DATABASE_URL=postgresql://m2a:m2a_secret@localhost:5432/m2a
DATABASE_URL=postgres://postgres:postgres@localhost:5432/m2a

# Production: use pgBouncer connection pooling (port 6432)
# DATABASE_URL=postgres://postgres:postgres@localhost:6432/m2a
# PGBOUNCER_POOL_MODE=transaction
# PGBOUNCER_DEFAULT_POOL_SIZE=25
# PGBOUNCER_MAX_CLIENT_CONN=100

# Redis Cache URL (Used by Relayer Rate Limiter)
REDIS_URL=redis://localhost:6379

# Vector & LLM Embeddings (Using Gemini Free tier OpenAI-compatible endpoint)
OPENAI_API_KEY=your_google_gemini_api_key_here
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# Override default embedding model if needed:
# OPENAI_EMBEDDING_MODEL=text-embedding-004

# M2A Gateway (authorization / policy) settings
# URL runtime should call for policy checks (runtime default: http://localhost:4010)
M2A_GATEWAY_URL=http://localhost:4010

# Gateway listen port
M2A_GATEWAY_PORT=4010

# Rate limiting (runtime)
RATE_LIMIT_MAX=100
RATE_LIMIT_EXECUTE_MAX=20
RATE_LIMIT_AUTHZ_MAX=30

# HTTPS termination (set NODE_ENV=production to enable redirect)
# NODE_ENV=production
# HTTPS_REDIRECT=true

# Comma-separated list of tools to block at the gateway (optional)
# Example: M2A_BLOCKED_TOOLS=store_to_walrus,sui_query
M2A_BLOCKED_TOOLS=

# Comma-separated list of specific actions to block (optional)
# Example: M2A_BLOCKED_ACTIONS=agent.runStep,tool.execute
M2A_BLOCKED_ACTIONS=

# M2A Smart Contracts (suffixed with SUI_NETWORK)
M2A_PACKAGE_ID_testnet=0xa71d8a8af046a5a1e031065ce668fa2a4f5d8495a4f1f2c14125994cf244bc66
# M2A_PACKAGE_ID_mainnet=0x...
M2A_REGISTRY_ID_testnet=0xc0f1c1295bd1ebc0c3bf9f2b8bd55e4013916a5d71716a6c4c930e43ec8d77ae
# M2A_REGISTRY_ID_mainnet=0x...
